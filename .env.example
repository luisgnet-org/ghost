# Ghost Daemon Configuration
# Copy this to .env and fill in your values.

# LLM (OpenAI-compatible endpoint — vLLM, ollama, etc.)
LLM_API_KEY=local
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=default

# Paths (defaults work for most setups)
# GHOST_HOME=/path/to/ghost
# GHOST_RUNS_DIR=/path/to/ghost/run
